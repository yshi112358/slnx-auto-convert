{
  "name": "slnx-auto-convert",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Yuki Shimada",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/yshi112358/slnx-auto-convert.git"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.csproj"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "slnx-auto-convert.convertWorkspace",
        "title": "%command.convertWorkspace.title%"
      },
      {
        "command": "slnx-auto-convert.disableUnityVsCodePatch",
        "title": "%command.disableUnityVsCodePatch.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "slnxAutoConvert.debounceMs": {
          "type": "number",
          "default": 800,
          "minimum": 0,
          "description": "%config.debounceMs.description%"
        },
        "slnxAutoConvert.watchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.watchEnabled.description%"
        },
        "slnxAutoConvert.autoCreateVstuPatchDisable": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoCreateVstuPatchDisable.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "uuid": "^11.1.1"
  }
}
